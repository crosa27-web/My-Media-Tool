<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Lightweight YouTube Player</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <style>
        body { font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #1f2937; }
        ::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #6b7280; }
        #youtube-player-container { position: fixed; top: 0; left: 0; width: 640px; height: 360px; z-index: -1; opacity: 0; pointer-events: none; }
        .h-screen-dynamic { height: 100vh; height: -webkit-fill-available; }
        input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; }
        input[type=range]:focus { outline: none; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 14px; width: 14px; border-radius: 50%; background: #fca5a5; cursor: pointer; margin-top: -5px; }
        input[type=range]::-moz-range-thumb { height: 14px; width: 14px; border-radius: 50%; background: #fca5a5; cursor: pointer; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; cursor: pointer; background: #4b5563; border-radius: 2px; }
        input[type=range]::-moz-range-track { width: 100%; height: 4px; cursor: pointer; background: #4b5563; border-radius: 2px; }

        /* Custom style to allow title to show up to two lines before truncating */
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.25; /* ensures lines stack nicely */
            max-height: 2.5em; /* 2 lines * 1.25 line-height * font-size (approx) */
        }
    </style>
</head>
<body class="bg-gray-900 text-gray-200">
    <div id="root"></div>
    <div id="youtube-player-container"></div>

    <script type="text/babel">
        window.onerror = function(message, source, lineno, colno, error) {
            const rootDiv = document.getElementById('root');
            if (rootDiv) {
                rootDiv.innerHTML = `<div style="background-color: #4c1d1d; color: #fecaca; padding: 1rem; border: 2px solid #ef4444; margin: 1rem; font-family: monospace; border-radius: 0.5rem;"><h1 style="font-size: 1.25rem; font-weight: bold; margin-bottom: 0.5rem;">A critical error occurred.</h1><p style="margin-bottom: 0.25rem; word-wrap: break-word;"><strong>Error:</strong> ${message}</p><p style="margin-bottom: 0.25rem;"><strong>Line:</strong> ${lineno}</p><p>Please reload and try again.</p></div>`;
            }
            return true;
        };

        const { useState, useEffect, useCallback, createContext, useContext } = React;
        const AppContext = createContext(null);

        const Icons = {
            Youtube: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17Z"/><path d="m10 15 5-3-5-3z"/></svg>),
            Video: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>),
            LogIn: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>),
            Menu: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>),
            X: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>),
            Search: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>),
            Heart: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>),
            ChevronDown: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m6 9 6 6 6-6"/></svg>),
            Plus: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>),
            Edit2: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>),
            Trash2: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>),
            Music: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>),
            ListPlus: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M11 12H3"/><path d="M16 6H3"/><path d="M16 18H3"/><path d="M18 9v6"/><path d="M21 12h-6"/></svg>),
            Repeat: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/></svg>),
            Repeat1: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/><path d="M11 10h1v4"/></svg>),
            Shuffle: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"/><path d="m18 2 4 4-4 4"/><path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"/><path d="M22 18h-1.9c-1.5 0-2.9-.9-3.6-2.2"/><path d="m18 22 4-4-4-4"/></svg>),
            SkipBack: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" x2="5" y1="19" y2="5"/></svg>),
            Play: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>),
            Pause: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="4" height="16" x="6" y="4"/><rect width="4" height="16" x="14" y="4"/></svg>),
            SkipForward: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" x2="19" y1="5" y2="19"/></svg>),
            PlusSquare: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>),
            ListMusic: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M21 15V6"/><path d="M18.5 18a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/><path d="M12 12H3"/><path d="M16 6H3"/><path d="M12 18H3"/></svg>),
            Rewind: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polygon points="11 19 2 12 11 5 11 19"/><polygon points="22 19 13 12 22 5 22 19"/></svg>),
            FastForward: (props) => (<svg {...props} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polygon points="13 19 22 12 13 5 13 19"/><polygon points="2 19 11 12 2 5 2 19"/></svg>),
        };
        
        const loadScript = (src) => new Promise((resolve, reject) => {
            if (document.querySelector(`script[src="${src}"]`)) return resolve();
            const script = document.createElement('script');
            script.src = src;
            script.async = true;
            script.defer = true;
            script.onload = () => resolve();
            script.onerror = () => reject(new Error(`Script load error for ${src}`));
            document.head.appendChild(script);
        });

        function App() {
            const [appStatus, setAppStatus] = useState('INITIALIZING');
            const [userCredentials, setUserCredentials] = useState({
                apiKey: localStorage.getItem('ytm_apiKey') || '',
                clientId: localStorage.getItem('ytm_clientId') || ''
            });
            const [accessToken, setAccessToken] = useState(localStorage.getItem('ytm_accessToken') || null);
            const [error, setError] = useState(null);

            const [userProfile, setUserProfile] = useState(null);
            const [player, setPlayer] = useState(null);
            const [currentTrack, setCurrentTrack] = useState(null);
            const [isPlaying, setIsPlaying] = useState(false);
            const [playbackQueue, setPlaybackQueue] = useState([]);
            const [currentQueueIndex, setCurrentQueueIndex] = useState(-1);
            const [playbackMode, setPlaybackMode] = useState('NORMAL');
            const [ytPlaylists, setYtPlaylists] = useState([]);
            const [activePlaylist, setActivePlaylist] = useState(null);
            const [activePlaylistItems, setActivePlaylistItems] = useState([]);
            const [searchResults, setSearchResults] = useState([]);
            const [localPlaylists, setLocalPlaylists] = useState(() => JSON.parse(localStorage.getItem('ytm_localPlaylists') || '[]'));
            const [favorites, setFavorites] = useState(() => JSON.parse(localStorage.getItem('ytm_favorites') || '[]'));
            const [activeView, setActiveView] = useState('YT_PLAYLISTS');
            const [isSidebarOpen, setIsSidebarOpen] = useState(false);
            const [isPlaylistModalOpen, setIsPlaylistModalOpen] = useState(false);
            const [playlistToEdit, setPlaylistToEdit] = useState(null);
            const [songToAdd, setSongToAdd] = useState(null);
            const [progress, setProgress] = useState(0);
            const [duration, setDuration] = useState(0);
            const [isSeeking, setIsSeeking] = useState(false);

            const handleCredentialSubmit = (apiKey, clientId) => {
                localStorage.setItem('ytm_apiKey', apiKey);
                localStorage.setItem('ytm_clientId', clientId);
                setUserCredentials({ apiKey, clientId });
                window.location.reload();
            };

            const handleLogin = () => {
                const { clientId } = userCredentials;
                const redirectUri = window.location.origin + window.location.pathname;
                const authUrl = `https://accounts.google.com/o/oauth2/v2/auth?` +
                    `client_id=${clientId}&` +
                    `redirect_uri=${encodeURIComponent(redirectUri)}&` +
                    `response_type=token&` +
                    `scope=${encodeURIComponent('https://www.googleapis.com/auth/youtube.readonly')}`;
                window.location.href = authUrl;
            };

            const playSong = useCallback((song, queue, index) => {
                if (player && song?.id) {
                    player.loadVideoById(song.id);
                    player.playVideo();
                    setCurrentTrack(song);
                    setPlaybackQueue(queue);
                    setCurrentQueueIndex(index);
                    setProgress(0);
                }
            }, [player]);
            
            const playNextSong = useCallback(() => {
                if (playbackQueue.length === 0) return;
                let nextIndex;
                if (playbackMode === 'SHUFFLE') nextIndex = Math.floor(Math.random() * playbackQueue.length);
                else if (playbackMode === 'REPEAT_ONE') nextIndex = currentQueueIndex;
                else {
                    nextIndex = currentQueueIndex + 1;
                    if (nextIndex >= playbackQueue.length) nextIndex = playbackMode === 'REPEAT_ALL' ? 0 : -1;
                }
                if (nextIndex !== -1) playSong(playbackQueue[nextIndex], playbackQueue, nextIndex);
                else setIsPlaying(false);
            }, [playbackQueue, currentQueueIndex, playbackMode, playSong]);

            const onPlayerStateChange = useCallback((event) => {
                const state = event.data;
                if (state === YT.PlayerState.PLAYING) {
                    setIsPlaying(true);
                    if (player && typeof player.getDuration === 'function') setDuration(player.getDuration());
                } else if (state === YT.PlayerState.PAUSED) setIsPlaying(false);
                else if (state === YT.PlayerState.ENDED) playNextSong();
            }, [playNextSong, player]);

            const apiRequest = useCallback(async (endpoint) => {
                const url = `https://www.googleapis.com/youtube/v3/${endpoint}`;
                const headers = { 'Authorization': `Bearer ${accessToken}` };
                const response = await fetch(url, { headers });
                if (!response.ok) {
                    if (response.status === 401) { // Unauthorized
                        localStorage.removeItem('ytm_accessToken');
                        setAccessToken(null);
                        setAppStatus('READY_TO_LOGIN');
                        setError("Session expired. Please sign in again.");
                    }
                    throw new Error(`API request failed with status ${response.status}`);
                }
                return response.json();
            }, [accessToken]);

            useEffect(() => {
                const hash = window.location.hash;
                if (hash) {
                    const params = new URLSearchParams(hash.substring(1));
                    const token = params.get('access_token');
                    if (token) {
                        localStorage.setItem('ytm_accessToken', token);
                        setAccessToken(token);
                        window.history.replaceState({}, document.title, window.location.pathname + window.location.search);
                    }
                }

                if (!userCredentials.apiKey || !userCredentials.clientId) {
                    setAppStatus('CREDENTIALS_NEEDED');
                    return;
                }

                loadScript("https://www.youtube.com/iframe_api")
                    .then(() => {
                        window.onYouTubeIframeAPIReady = () => {
                            new YT.Player('youtube-player-container', {
                                height: '1', width: '1',
                                events: { 'onReady': (e) => setPlayer(e.target), 'onStateChange': onPlayerStateChange }
                            });
                        };
                        if (window.YT && window.YT.Player) {
                           window.onYouTubeIframeAPIReady();
                        }
                    }).catch(err => {
                        console.error(err);
                        setError("Could not load the YouTube Player. Please check your connection.");
                        setAppStatus('ERROR');
                    });
                
                if (localStorage.getItem('ytm_accessToken')) {
                    setAppStatus('LOGGED_IN');
                } else {
                    setAppStatus('READY_TO_LOGIN');
                }
            }, [onPlayerStateChange, userCredentials]);
            
            useEffect(() => {
                const fetchData = async () => {
                    if (appStatus === 'LOGGED_IN' && player) {
                        try {
                            const profileData = await apiRequest('channels?part=snippet&mine=true');
                            if (profileData.items && profileData.items.length > 0) {
                                const profile = profileData.items[0].snippet;
                                setUserProfile({ name: profile.title, avatar: profile.thumbnails.default.url });
                            }
                            const playlistsData = await apiRequest('playlists?part=snippet,contentDetails&mine=true&maxResults=50');
                            setYtPlaylists(playlistsData.items);
                        } catch (err) {
                            console.error("Fetch data error:", err);
                        }
                    }
                };
                fetchData();
            }, [appStatus, player, apiRequest]);

            useEffect(() => {
                let progressInterval;
                if (isPlaying && !isSeeking && player) {
                    progressInterval = setInterval(() => {
                        if (player && typeof player.getCurrentTime === 'function') {
                            setProgress(player.getCurrentTime());
                            setDuration(player.getDuration());
                        }
                    }, 500);
                }
                return () => clearInterval(progressInterval);
            }, [isPlaying, isSeeking, player]);

            useEffect(() => { localStorage.setItem('ytm_localPlaylists', JSON.stringify(localPlaylists)); }, [localPlaylists]);
            useEffect(() => { localStorage.setItem('ytm_favorites', JSON.stringify(favorites)); }, [favorites]);

            const fetchPlaylistItems = useCallback(async (playlistId) => {
                try {
                    const data = await apiRequest(`playlistItems?part=snippet&playlistId=${playlistId}&maxResults=50`);
                    const items = data.items.filter(item => item.snippet?.resourceId?.videoId).map(item => ({ id: item.snippet.resourceId.videoId, title: item.snippet.title, artist: item.snippet.videoOwnerChannelTitle, thumbnail: item.snippet.thumbnails.medium?.url || item.snippet.thumbnails.default.url }));
                    setActivePlaylistItems(items);
                    const selectedPlaylist = ytPlaylists.find(p => p.id === playlistId);
                    setActivePlaylist(selectedPlaylist?.snippet?.title);
                } catch (err) { setError("Could not fetch playlist items."); }
            }, [apiRequest, ytPlaylists]);

            const searchYoutube = useCallback(async (query, searchType) => {
                if (!query) return;
                try {
                    let endpoint = `search?part=snippet&q=${encodeURIComponent(query)}&type=video&maxResults=25&key=${userCredentials.apiKey}`;
                    if (searchType === 'MUSIC') endpoint += '&videoCategoryId=10';
                    const response = await fetch(`https://www.googleapis.com/youtube/v3/${endpoint}`);
                    const data = await response.json();
                    const items = data.items.map(item => ({ id: item.id.videoId, title: item.snippet.title, artist: item.snippet.channelTitle, thumbnail: item.snippet.thumbnails.medium.url }));
                    setSearchResults(items);
                    setActiveView('SEARCH');
                } catch (err) { setError("Search failed."); }
            }, [userCredentials.apiKey]);

            const handleLogout = () => { localStorage.clear(); window.location.href = window.location.pathname; };
            const playPause = () => { if(!player) return; isPlaying ? player.pauseVideo() : player.playVideo(); };
            const playPrevSong = () => { if (currentQueueIndex > 0) playSong(playbackQueue[currentQueueIndex - 1], playbackQueue, currentQueueIndex - 1); };
            const shuffleAndPlay = (songs) => { const shuffled = [...songs].sort(() => Math.random() - 0.5); setPlaybackQueue(shuffled); playSong(shuffled[0], shuffled, 0); };
            const togglePlaybackMode = () => { const modes = ['NORMAL', 'REPEAT_ALL', 'REPEAT_ONE', 'SHUFFLE']; setPlaybackMode(modes[(modes.indexOf(playbackMode) + 1) % modes.length]); };
            const createOrUpdateLocalPlaylist = (playlistData) => { if (playlistToEdit) setLocalPlaylists(localPlaylists.map(p => p.id === playlistToEdit.id ? { ...p, ...playlistData } : p)); else setLocalPlaylists([...localPlaylists, { id: `local_${Date.now()}`, title: playlistData.title, items: [] }]); setIsPlaylistModalOpen(false); setPlaylistToEdit(null); };
            const deleteLocalPlaylist = (playlistId) => { setLocalPlaylists(localPlaylists.filter(p => p.id !== playlistId)); if (activePlaylist === localPlaylists.find(p => p.id === playlistId)?.title) { setActiveView('YT_PLAYLISTS'); setActivePlaylistItems([]); } };
            const addSongToPlaylist = (playlistId) => { if (!songToAdd) return; setLocalPlaylists(localPlaylists.map(p => p.id === playlistId && !p.items.some(item => item.id === songToAdd.id) ? { ...p, items: [...p.items, songToAdd] } : p)); setSongToAdd(null); };
            const removeSongFromPlaylist = (playlistId, songId) => { setLocalPlaylists(localPlaylists.map(p => { if (p.id === playlistId) { const newItems = p.items.filter(item => item.id !== songId); setActivePlaylistItems(newItems); return { ...p, items: newItems }; } return p; })); };
            const viewLocalPlaylist = (playlist) => { setActivePlaylistItems(playlist.items); setActivePlaylist(playlist.title); setActiveView('LOCAL_PLAYLIST_ITEMS'); setIsSidebarOpen(false); };
            const isFavorite = (songId) => favorites.some(fav => fav.id === songId);
            const toggleFavorite = (song) => isFavorite(song.id) ? setFavorites(favorites.filter(fav => fav.id !== song.id)) : setFavorites([...favorites, song]);
            const handleSeek = (newTime) => { if(player) { player.seekTo(newTime, true); setProgress(newTime); } };
            const seek = (seconds) => { if (player && typeof player.getCurrentTime === 'function') { const currentTime = player.getCurrentTime(); player.seekTo(currentTime + seconds, true); } };

            const contextValue = { userProfile, ytPlaylists, activeView, localPlaylists, favorites, activePlaylist, activePlaylistItems, searchResults, currentTrack, isPlaying, playbackMode, progress, duration, isSeeking, setIsSeeking, handleSeek, handleLogin, handleLogout, fetchPlaylistItems, searchYoutube, setActiveView, viewLocalPlaylist, playSong, playPause, playNextSong, playPrevSong, togglePlaybackMode, setIsSidebarOpen, setIsPlaylistModalOpen, setPlaylistToEdit, deleteLocalPlaylist, setSongToAdd, toggleFavorite, isFavorite, removeSongFromPlaylist, seek, shuffleAndPlay };
            
            if (appStatus === 'ERROR') return <div className="flex items-center justify-center h-screen-dynamic"><div className="bg-red-900/50 text-red-300 p-4 rounded-md text-center"><h1>Error</h1><p>{error}</p></div></div>;
            if (appStatus === 'INITIALIZING' || (appStatus === 'LOGGED_IN' && !player)) return <div className="flex items-center justify-center h-screen-dynamic"><Spinner /></div>;
            if (appStatus === 'CREDENTIALS_NEEDED') return <CredentialScreen onSubmit={handleCredentialSubmit} />;
            if (appStatus === 'READY_TO_LOGIN') return <LoginScreen onLogin={handleLogin} error={error} />;

            return (
                <AppContext.Provider value={contextValue}>
                    <div className="h-screen-dynamic w-screen flex flex-col bg-gray-900 overflow-hidden">
                        <MobileHeader />
                        <div className="flex flex-1 overflow-y-hidden">
                            <Sidebar isOpen={isSidebarOpen} setIsOpen={setIsSidebarOpen} />
                            <MainContent />
                        </div>
                        {currentTrack && <PlayerControls />}
                        {isPlaylistModalOpen && <PlaylistModal onClose={() => { setIsPlaylistModalOpen(false); setPlaylistToEdit(null); }} onSave={createOrUpdateLocalPlaylist} playlist={playlistToEdit} />}
                        {songToAdd && <AddToPlaylistModal song={songToAdd} localPlaylists={localPlaylists} onAdd={addSongToPlaylist} onClose={() => setSongToAdd(null)} onNewPlaylist={() => { setIsPlaylistModalOpen(true); setSongToAdd(null); }} />}
                    </div>
                </AppContext.Provider>
            );
        }
        
        // --- COMPONENTS ---
        function CredentialScreen({ onSubmit }) { const [apiKey, setApiKey] = useState(''); const [clientId, setClientId] = useState(''); const handleSubmit = (e) => { e.preventDefault(); if (apiKey && clientId) onSubmit(apiKey, clientId); }; return ( <div className="min-h-screen bg-gray-800 flex flex-col items-center justify-center p-4"><div className="w-full max-w-md bg-gray-900 rounded-lg shadow-xl p-8 text-center"><Icons.Youtube className="mx-auto h-16 w-16 text-red-500 mb-4" /><h1 className="text-2xl font-bold text-white mb-2">Welcome!</h1><p className="text-gray-400 mb-6">Enter your Google Cloud API credentials.</p><form onSubmit={handleSubmit} className="space-y-4"><input type="text" value={apiKey} onChange={(e) => setApiKey(e.target.value)} placeholder="API Key" className="w-full bg-gray-800 border border-gray-700 rounded-md px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500" /><input type="text" value={clientId} onChange={(e) => setClientId(e.target.value)} placeholder="OAuth 2.0 Client ID" className="w-full bg-gray-800 border border-gray-700 rounded-md px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500" /><button type="submit" className="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-md transition duration-300">Save & Continue</button></form><p className="text-xs text-gray-500 mt-6">Keys are stored in your browser's localStorage.<a href="https://developers.google.com/youtube/v3/getting-started" target="_blank" rel="noopener noreferrer" className="text-red-400 hover:underline ml-1">How to get credentials?</a></p></div></div> ); }
        
        function LoginScreen({ onLogin, error }) {
            const redirectUri = window.location.origin + window.location.pathname;
            const [copied, setCopied] = useState(false);
            const copyToClipboard = () => {
                const input = document.getElementById('redirect-uri-input');
                if (input) {
                    input.select();
                    input.setSelectionRange(0, 99999); 
                    try {
                        document.execCommand('copy');
                        setCopied(true);
                        setTimeout(() => setCopied(false), 2000);
                    } catch (err) {
                        console.error('Failed to copy text: ', err);
                    }
                }
            };

            return (
                <div className="h-screen-dynamic bg-gray-900 flex items-center justify-center text-center p-4">
                    <div className="w-full max-w-2xl">
                        <Icons.Youtube className="mx-auto h-24 w-24 text-red-500 mb-6" />
                        <h1 className="text-4xl font-bold text-white mb-2">Lightweight YouTube Player</h1>
                        <p className="text-gray-400 mb-8">Sign in to access your library.</p>
                        <button onClick={onLogin} className="bg-red-600 text-white font-semibold py-3 px-8 rounded-full hover:bg-red-700 transition duration-300 flex items-center mx-auto">
                            <Icons.LogIn className="mr-2 h-5 w-5" /> Sign in with Google
                        </button>
                        {error && <p className="text-red-400 mt-4 bg-red-900/50 p-3 rounded-md">{error}</p>}
                        <div className="text-left mx-auto mt-8 bg-gray-800 border border-gray-700 rounded-lg p-6">
                            <h2 className="font-bold text-lg text-gray-200 mb-3">First Time Setup / Troubleshooting</h2>
                            <p className="text-sm text-gray-400 mb-4">If you see a <code className="bg-gray-900 text-red-400 px-1 py-0.5 rounded">"redirect_uri_mismatch"</code> error from Google, you must add your app's URL to your Google Cloud project.</p>
                            <p className="text-sm text-gray-300 mb-2 font-medium">Your app's required redirect URI is:</p>
                            <div className="flex items-center gap-2 bg-gray-900 p-3 rounded-md">
                                <input id="redirect-uri-input" type="text" readOnly value={redirectUri} className="bg-transparent text-gray-200 w-full outline-none font-mono text-sm" />
                                <button onClick={copyToClipboard} className="bg-gray-700 hover:bg-gray-600 text-gray-200 text-xs font-bold py-1 px-3 rounded-md whitespace-nowrap">{copied ? 'Copied!' : 'Copy URL'}</button>
                            </div>
                             <p className="text-xs text-gray-500 mt-4">
                                1. Go to the <a href="https://console.cloud.google.com/apis/credentials" target="_blank" rel="noopener noreferrer" className="text-blue-400 hover:underline">Google Cloud Console</a>.<br/>
                                2. Select your project and click on your OAuth 2.0 Client ID.<br/>
                                3. Under "Authorized redirect URIs", click "ADD URI".<br/>
                                4. Paste the exact URL you copied above and save your changes.
                            </p>
                        </div>
                    </div>
                </div>
            );
        }

        function MobileHeader() { const { userProfile, setIsSidebarOpen } = useContext(AppContext); return ( <div className="md:hidden flex-shrink-0 flex items-center justify-between p-3 bg-gray-900 border-b border-gray-800"><button onClick={() => setIsSidebarOpen(true)} className="p-2"><Icons.Menu /></button><div className="flex items-center">{userProfile && <img src={userProfile.avatar} alt={userProfile.name} className="h-8 w-8 rounded-full" />}</div></div> ); }
        function Sidebar({ isOpen, setIsOpen }) { const { userProfile, handleLogout, activeView, setActiveView, ytPlaylists, fetchPlaylistItems, localPlaylists, setIsPlaylistModalOpen, viewLocalPlaylist, deleteLocalPlaylist, setPlaylistToEdit, favorites } = useContext(AppContext); const [showYtPlaylists, setShowYtPlaylists] = useState(true); const [showLocalPlaylists, setShowLocalPlaylists] = useState(true); const handleYtPlaylistClick = (id) => { fetchPlaylistItems(id); setActiveView('YT_PLAYLIST_ITEMS'); setIsOpen(false); }; const handleLocalPlaylistClick = (playlist) => { viewLocalPlaylist(playlist); }; const handleFavoritesClick = () => { setActiveView('FAVORITES'); setIsOpen(false); }; return ( <> <div className={`fixed inset-0 bg-black bg-opacity-50 z-30 md:hidden transition-opacity ${isOpen ? 'opacity-100' : 'opacity-0 pointer-events-none'}`} onClick={() => setIsOpen(false)}></div> <aside className={`absolute md:relative flex flex-col bg-black md:bg-gray-900 text-white w-64 md:w-72 h-full z-40 transform ${isOpen ? 'translate-x-0' : '-translate-x-full'} md:translate-x-0 transition-transform duration-300 ease-in-out border-r border-gray-800`}><div className="p-4 border-b border-gray-800 flex items-center justify-between"><div className="flex items-center space-x-3"><Icons.Youtube className="h-8 w-8 text-red-500" /><span className="text-lg font-bold">YT Player</span></div><button className="md:hidden p-1" onClick={() => setIsOpen(false)}><Icons.X/></button></div>{userProfile && <div className="p-4 border-b border-gray-800 flex items-center space-x-3"><img src={userProfile.avatar} alt="User" className="h-10 w-10 rounded-full" /><div><p className="font-semibold">{userProfile.name}</p><button onClick={handleLogout} className="text-sm text-red-400 hover:underline">Sign Out & Reset</button></div></div>}<nav className="flex-1 overflow-y-auto p-4 space-y-4"><NavItem icon={Icons.Search} text="Search" active={activeView === 'SEARCH'} onClick={() => { setActiveView('SEARCH'); setIsOpen(false); }} /><NavItem icon={Icons.Heart} text="Favorites" active={activeView === 'FAVORITES'} onClick={handleFavoritesClick}><span className="text-xs bg-gray-700 text-gray-300 rounded-full px-2 py-0.5">{favorites.length}</span></NavItem><CollapsibleSection title="YouTube Playlists" count={ytPlaylists.length} isOpen={showYtPlaylists} setIsOpen={setShowYtPlaylists}>{ytPlaylists.map(pl => ( <PlaylistItem key={pl.id} text={pl.snippet.title} onClick={() => handleYtPlaylistClick(pl.id)} /> ))}</CollapsibleSection><CollapsibleSection title="My Playlists" count={localPlaylists.length} isOpen={showLocalPlaylists} setIsOpen={setShowLocalPlaylists} actionIcon={Icons.Plus} onAction={() => setIsPlaylistModalOpen(true)}>{localPlaylists.map(pl => ( <PlaylistItem key={pl.id} text={pl.title} onClick={() => handleLocalPlaylistClick(pl)} onEdit={(e) => { e.stopPropagation(); setPlaylistToEdit(pl); setIsPlaylistModalOpen(true); }} onDelete={(e) => { e.stopPropagation(); deleteLocalPlaylist(pl.id); }}/> ))}</CollapsibleSection></nav></aside> </> ); }
        const NavItem = ({ icon: IconComponent, text, active, onClick, children }) => ( <a href="#" onClick={(e) => { e.preventDefault(); onClick(); }} className={`flex items-center justify-between p-2 rounded-md transition-colors ${active ? 'bg-gray-700' : 'hover:bg-gray-800'}`}><div className="flex items-center space-x-3"><IconComponent className={`h-5 w-5 ${active ? 'text-red-400' : 'text-gray-400'}`} /><span className="font-medium">{text}</span></div>{children}</a> );
        const CollapsibleSection = ({ title, count, isOpen, setIsOpen, actionIcon: ActionIcon, onAction, children }) => ( <div><button onClick={() => setIsOpen(!isOpen)} className="w-full flex items-center justify-between p-2 rounded-md hover:bg-gray-800"><div className="flex items-center space-x-3"><h3 className="font-bold text-gray-400 text-sm uppercase tracking-wider">{title}</h3><span className="text-xs bg-gray-700 text-gray-300 rounded-full px-2 py-0.5">{count}</span></div><div className="flex items-center">{onAction && <button onClick={(e) => {e.stopPropagation(); onAction();}} className="p-1 hover:bg-gray-700 rounded-full mr-2"><ActionIcon className="h-4 w-4" /></button>}<Icons.ChevronDown className={`h-5 w-5 transition-transform ${isOpen ? 'rotate-180' : ''}`} /></div></button>{isOpen && <div className="mt-2 pl-4 space-y-1">{children}</div>}</div> );
        const PlaylistItem = ({ text, onClick, onEdit, onDelete }) => ( <a href="#" onClick={(e) => { e.preventDefault(); onClick(); }} className="group flex items-center justify-between p-2 rounded-md hover:bg-gray-800 text-gray-300"><span className="truncate">{text}</span><div className="flex items-center opacity-0 group-hover:opacity-100 transition-opacity">{onEdit && <button onClick={onEdit} className="p-1 hover:text-white"><Icons.Edit2 className="h-4 w-4" /></button>}{onDelete && <button onClick={onDelete} className="p-1 hover:text-red-400"><Icons.Trash2 className="h-4 w-4" /></button>}</div></a> );
        function MainContent() { const { activeView } = useContext(AppContext); const renderView = () => { switch(activeView) { case 'SEARCH': return <SearchView />; case 'YT_PLAYLISTS': return <WelcomeView />; case 'FAVORITES': return <FavoritesView />; case 'YT_PLAYLIST_ITEMS': case 'LOCAL_PLAYLIST_ITEMS': return <PlaylistContentView />; default: return <WelcomeView />; } }; return ( <main className="flex-1 bg-gray-900 overflow-y-auto">{renderView()}</main> ); }
        function WelcomeView() { return ( <div className="p-8 text-center"><h1 className="text-4xl font-bold mb-4">Welcome</h1><p className="text-gray-400">Select a playlist from the sidebar to get started, or use the search to find music.</p></div> ); }
        function SearchView() { const { searchYoutube, searchResults, playSong, shuffleAndPlay } = useContext(AppContext); const [query, setQuery] = useState(''); const [searchType, setSearchType] = useState('MUSIC'); return ( <div className="p-4 md:p-8"><div className="mb-4 flex justify-center"><div className="bg-gray-800 rounded-full p-1 flex items-center"><button onClick={() => setSearchType('MUSIC')} className={`px-4 py-1.5 text-sm font-semibold rounded-full ${searchType === 'MUSIC' ? 'bg-red-600 text-white' : 'text-gray-400'}`}><Icons.Music className="inline-block h-4 w-4 mr-1"/> Music</button><button onClick={() => setSearchType('VIDEO')} className={`px-4 py-1.5 text-sm font-semibold rounded-full ${searchType === 'VIDEO' ? 'bg-red-600 text-white' : 'text-gray-400'}`}><Icons.Video className="inline-block h-4 w-4 mr-1"/> Videos</button></div></div><form onSubmit={(e) => { e.preventDefault(); searchYoutube(query, searchType); }} className="mb-8 flex"><input type="text" value={query} onChange={(e) => setQuery(e.target.value)} placeholder={`Search for ${searchType.toLowerCase()}...`} className="w-full bg-gray-800 border-gray-700 rounded-l-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500" /><button type="submit" className="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-r-md">Search</button></form>{searchResults.length > 0 && ( <> <div className="mb-4"><button onClick={() => shuffleAndPlay(searchResults)} className="bg-red-600 text-white font-semibold py-2 px-5 rounded-full hover:bg-red-700 transition duration-300 flex items-center"><Icons.Shuffle className="mr-2 h-5 w-5" /> Shuffle Play</button></div> <SongList songs={searchResults} onPlay={(song, index) => playSong(song, searchResults, index)} /> </> )}</div> ); }
        function PlaylistContentView() { const { activePlaylist, activePlaylistItems, playSong, shuffleAndPlay, localPlaylists, removeSongFromPlaylist } = useContext(AppContext); const isLocal = localPlaylists.some(p => p.title === activePlaylist); const playlist = isLocal ? localPlaylists.find(p => p.title === activePlaylist) : null; return ( <div className="p-4 md:p-8"><div className="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4"><div className="flex items-center"><Icons.Music className="h-10 w-10 text-red-400 mr-4" /><div><p className="text-sm text-gray-400">Playlist</p><h1 className="text-3xl font-bold">{activePlaylist || 'Playlist'}</h1></div></div>{activePlaylistItems.length > 0 && <button onClick={() => shuffleAndPlay(activePlaylistItems)} className="bg-red-600 text-white font-semibold py-2 px-5 rounded-full hover:bg-red-700 transition duration-300 flex items-center w-fit"><Icons.Shuffle className="mr-2 h-5 w-5" /> Shuffle Play</button>}</div><SongList songs={activePlaylistItems} onPlay={(song, index) => playSong(song, activePlaylistItems, index)} isLocalPlaylist={isLocal} playlistId={playlist?.id} onRemove={removeSongFromPlaylist}/></div> ); }
        function FavoritesView() { const { favorites, playSong, shuffleAndPlay } = useContext(AppContext); return ( <div className="p-4 md:p-8"><div className="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4"><div className="flex items-center"><Icons.Heart className="h-10 w-10 text-red-400 mr-4" /><div><p className="text-sm text-gray-400">Your</p><h1 className="text-3xl font-bold">Favorites</h1></div></div>{favorites.length > 0 && <button onClick={() => shuffleAndPlay(favorites)} className="bg-red-600 text-white font-semibold py-2 px-5 rounded-full hover:bg-red-700 transition duration-300 flex items-center w-fit"><Icons.Shuffle className="mr-2 h-5 w-5" /> Shuffle Play</button>}</div>{favorites.length > 0 ? ( <SongList songs={favorites} onPlay={(song, index) => playSong(song, favorites, index)} /> ) : ( <p className="text-gray-400">Click the heart icon on a song to add it here.</p> )}</div> ) }
        function SongList({ songs, onPlay, isLocalPlaylist = false, playlistId = null, onRemove }) { 
            const { setSongToAdd, toggleFavorite, isFavorite } = useContext(AppContext); 
            if (!songs || songs.length === 0) { return <p className="text-gray-400">No songs found.</p> } 
            
            return ( 
                <div className="space-y-2 pb-24">
                    {songs.map((song, index) => ( 
                        <div key={song.id + '-' + index} className="group flex items-center p-2 rounded-md hover:bg-gray-800 transition-colors">
                            <div className="flex items-center flex-1 min-w-0 cursor-pointer" onClick={() => onPlay(song, index)}>
                                <img src={song.thumbnail} alt={song.title} className="h-12 w-12 rounded-md object-cover mr-4" />
                                <div className="flex-1 min-w-0">
                                    {/* --- CHANGE HERE: Changed 'truncate' to 'line-clamp-2' for better title readability --- */}
                                    <p className="font-semibold line-clamp-2">{song.title}</p>
                                    <p className="text-sm text-gray-400 truncate">{song.artist}</p>
                                </div>
                            </div>
                            <div className="flex items-center space-x-0 md:space-x-2 ml-4">
                                <button onClick={() => toggleFavorite(song)} className="p-2 text-gray-400 hover:text-red-500">
                                    <Icons.Heart className={`h-5 w-5 ${isFavorite(song.id) ? 'fill-current text-red-500' : ''}`} />
                                </button>
                                <button onClick={() => setSongToAdd(song)} className="p-2 text-gray-400 hover:text-white">
                                    <Icons.ListPlus className="h-5 w-5" />
                                </button>
                                {isLocalPlaylist && onRemove && ( 
                                    <button onClick={() => onRemove(playlistId, song.id)} className="p-2 text-gray-400 hover:text-red-500">
                                        <Icons.Trash2 className="h-5 w-5" />
                                    </button> 
                                )}
                            </div>
                        </div> 
                    ))}
                </div> 
            ); 
        }

        function PlayerControls() { const { currentTrack, isPlaying, playPause, playNextSong, playPrevSong, playbackMode, togglePlaybackMode, seek, progress, duration, isSeeking, setIsSeeking, handleSeek } = useContext(AppContext); const getPlaybackIcon = () => { switch(playbackMode) { case 'REPEAT_ALL': return <Icons.Repeat className="h-5 w-5 text-red-400"/>; case 'REPEAT_ONE': return <Icons.Repeat1 className="h-5 w-5 text-red-400"/>; case 'SHUFFLE': return <Icons.Shuffle className="h-5 w-5 text-red-400"/>; default: return <Icons.Repeat className="h-5 w-5"/>; } }; const formatTime = (seconds) => { if (isNaN(seconds) || seconds < 0) return '0:00'; const floored = Math.floor(seconds); const min = Math.floor(floored / 60); const sec = floored % 60; return `${min}:${sec < 10 ? '0' : ''}${sec}`; }; const handleSeekChange = (e) => { handleSeek(parseFloat(e.target.value)); }; if (!currentTrack) return null; return ( <footer className="flex-shrink-0 bg-gray-800 border-t border-gray-700 p-3 flex flex-col"><div className="flex items-center justify-between"><div className="flex items-center w-1/3 min-w-0"><img src={currentTrack.thumbnail} alt={currentTrack.title} className="h-12 w-12 rounded-md object-cover mr-3" /><div><p className="font-semibold text-sm truncate">{currentTrack.title}</p><p className="text-xs text-gray-400 truncate">{currentTrack.artist}</p></div></div><div className="flex items-center justify-center space-x-1 md:space-x-2"><button onClick={() => seek(-30)} className="p-2 hidden md:block"><Icons.Rewind className="h-6 w-6" /></button><button onClick={playPrevSong} className="p-2"><Icons.SkipBack className="h-6 w-6"/></button><button onClick={playPause} className="p-3 bg-red-600 rounded-full text-white shadow-lg">{isPlaying ? <Icons.Pause className="h-6 w-6" /> : <Icons.Play className="h-6 w-6" />}</button><button onClick={playNextSong} className="p-2"><Icons.SkipForward className="h-6 w-6"/></button><button onClick={() => seek(30)} className="p-2 hidden md:block"><Icons.FastForward className="h-6 w-6" /></button></div><div className="w-1/3 flex justify-end"><button onClick={togglePlaybackMode} className="p-2 hidden md:block">{getPlaybackIcon()}</button></div></div><div className="flex items-center space-x-2 mt-2"><span className="text-xs text-gray-400 w-10 text-center">{formatTime(progress)}</span><input type="range" min="0" max={duration || 0} value={progress || 0} onMouseDown={() => setIsSeeking(true)} onTouchStart={() => setIsSeeking(true)} onChange={handleSeekChange} onMouseUp={() => setIsSeeking(false)} onTouchEnd={() => setIsSeeking(false)} className="w-full" /><span className="text-xs text-gray-400 w-10 text-center">{formatTime(duration)}</span></div></footer> ); }
        function PlaylistModal({ onClose, onSave, playlist }) { const [title, setTitle] = useState(playlist?.title || ''); const handleSubmit = (e) => { e.preventDefault(); if (title) onSave({ title }); }; return ( <div className="fixed inset-0 bg-black bg-opacity-60 flex items-center justify-center z-50 p-4"><div className="bg-gray-800 rounded-lg shadow-xl w-full max-w-md p-6"><h2 className="text-xl font-bold mb-4">{playlist ? 'Edit Playlist' : 'New Playlist'}</h2><form onSubmit={handleSubmit}><input type="text" value={title} onChange={(e) => setTitle(e.target.value)} placeholder="Playlist Title" autoFocus className="w-full bg-gray-700 border border-gray-600 rounded-md px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500 mb-4" /><div className="flex justify-end space-x-2"><button type="button" onClick={onClose} className="px-4 py-2 rounded-md bg-gray-600 hover:bg-gray-500">Cancel</button><button type="submit" className="px-4 py-2 rounded-md bg-red-600 hover:bg-red-700">Save</button></div></form></div></div> ); }
        function AddToPlaylistModal({ song, localPlaylists, onAdd, onClose, onNewPlaylist }) { return ( <div className="fixed inset-0 bg-black bg-opacity-60 flex items-center justify-center z-50 p-4" onClick={onClose}><div className="bg-gray-800 rounded-lg shadow-xl w-full max-w-sm p-4" onClick={e => e.stopPropagation()}><h3 className="font-bold text-lg mb-2">Add to playlist</h3><p className="text-sm text-gray-400 mb-4 truncate">Adding: {song.title}</p><div className="max-h-60 overflow-y-auto space-y-1"><button onClick={onNewPlaylist} className="w-full text-left flex items-center p-2 rounded-md hover:bg-gray-700"><Icons.PlusSquare className="h-5 w-5 mr-3" /> New Playlist</button>{localPlaylists.map(pl => ( <button key={pl.id} onClick={() => onAdd(pl.id)} className="w-full text-left flex items-center p-2 rounded-md hover:bg-gray-700"><Icons.ListMusic className="h-5 w-5 mr-3" /> {pl.title}</button>))}</div></div></div> ); }
        function Spinner() { return ( <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-red-500"></div> ); }

        const container = document.getElementById('root');
        const root = ReactDOM.createRoot(container);
        root.render(<App />);

    </script>
</body>
</html>
